---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import {
  Computer,
  Archive,
  Search,
  UserRound,
  Pen,
  Folder,
  Axis3d,
  AppWindow,
} from "@lucide/astro";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import PortfolioCard from "@/components/PortfolioCard.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

type PortfolioLink = {
  name: string;
  description: string;
  href: string;
  icon: AstroComponentFactory;
};

const portfolioLinks: PortfolioLink[] = [
  {
    name: "ブログ",
    description: "このブログのソースです。Astroで構築されています。",
    href: "https://github.com/sheepla/blog",
    icon: Pen,
  },
  {
    name: "VExplorer",
    description:
      "C#とWPFで書かれた、VimmerのためのWindows用ファイルマネージャです。マウスとキーボードの両方で軽快に動作します。",
    href: "https://github.com/sheepla/VExplorer",
    icon: Folder,
  },
  {
    name: "lshw-tui",
    description:
      "LinuxのハードウェアツリーをTUIでサクっと確認できるTUIツールです。Rustとratatuiで構築されています。",
    href: "https://github.com/sheepla/lshw-tui",
    icon: Computer,
  },
  {
    name: "AxisEndpoints",
    description:
      "ASP.NET CoreでRequest-Endpoint-ResponseパターンやVertical Slice Architectureを実現するための補助ライブラリです。",
    href: "https://github.com/sheepla/AxisEndpoints",
    icon: Axis3d,
  },
  {
    name: "wmish",
    description:
      "WMI (Windows Management Instrumentation) を簡単に叩けるコマンドラインツールです。",
    href: "https://github.com/sheepla/wmish",
    icon: AppWindow,
  },
];

const title = "SheepLab.";
const description =
  "こんにちは、Sheeplaです。Sheepla の個人ブログへようこそ。趣味や技術的な知見、日頃思っていることなどについてまったり書いていきます。";
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section id="hero" class="border-border border-b pt-8 pb-6">
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        {title}
      </h1>
      <a
        target="_blank"
        href={`${import.meta.env.BASE_URL.replace(/\/?$/, "/")}rss.xml`}
        class="inline-block"
        aria-label="RSS Feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSSフィード</span>
      </a>

      <p>
        {description}
      </p>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    <section id="portfolio" class="border-border border-b py-12">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-semibold tracking-wide">Projects</h2>
        </div>
      </div>

      <ul class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {portfolioLinks.map(item => <PortfolioCard {...item} />)}
      </ul>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
