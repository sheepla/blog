---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

type Props = {
  name: string;
  description: string;
  href: string;
  icon: AstroComponentFactory;
};

import { ExternalLink } from "@lucide/astro";
const { name, description, href, icon: Icon } = Astro.props;
---

<li class="h-full">
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      "group border-border bg-background flex h-full flex-col gap-4 rounded-2xl border p-5 transition",
      "hover:border-accent/40 hover:-translate-y-1 hover:shadow-lg hover:shadow-black/5",
      "focus-visible:border-accent focus-visible:ring-accent/30 focus-visible:ring-2",
    ]}
  >
    <div class="flex items-start justify-between gap-3">
      <div
        class="bg-accent/10 text-accent flex size-12 shrink-0 items-center justify-center rounded-xl"
      >
        <Icon class="size-6 stroke-[2.25]" aria-hidden="true" />
      </div>
      <span
        class="text-muted-foreground group-hover:text-accent text-sm font-medium transition"
      >
        <ExternalLink />
      </span>
    </div>

    <div class="space-y-2">
      <h3 class="text-lg font-semibold tracking-tight">{name}</h3>
      <p class="text-muted-foreground text-sm leading-relaxed">{description}</p>
    </div>
  </a>
</li>
